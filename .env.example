# Variable names below are the same as Infisical secret names when using CLI injection.
# When using Infisical: infisical run -- ./start.sh or make run-infisical; .env can be omitted.
# When not using Infisical: copy this file to .env and fill in values.

# Public app metadata used in the approval-facing pages (/privacy, /terms, /support)
PUBLIC_APP_NAME=FinanceTracker
PUBLIC_APP_URL=http://127.0.0.1:5000
PUBLIC_SUPPORT_EMAIL=you@example.com
# Optional: dedicated inbox for security/privacy diligence (Plaid questionnaire). Can match support.
# PUBLIC_SECURITY_EMAIL=security@example.com
PUBLIC_OWNER_NAME=Your Name

# Plaid API credentials (get from https://dashboard.plaid.com/)
# Production (used when PLAID_ENV=production)
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here

# Sandbox/testing (used when PLAID_ENV=sandbox or development). Optional; falls back to PLAID_* above.
# PLAID_SANDBOX_CLIENT_ID=your_sandbox_client_id
# PLAID_SANDBOX_SECRET=your_sandbox_secret

# Environment: 'sandbox' (test), 'development', or 'production' (live accounts)
# Use production only after Plaid has approved your app for live access.
PLAID_ENV=sandbox

# Comma-separated list of Plaid products to use.
# Default approval-friendly scope for this app is transactions + investments.
PLAID_PRODUCTS=transactions,investments

# Comma-separated list of country codes
# Example: 'US' for United States
PLAID_COUNTRY_CODES=US

# Redirect URI for OAuth flows (required for production; some institutions use OAuth)
# Must be registered in Plaid Dashboard → Keys → Redirect URIs for your environment.
# Local dev: http://127.0.0.1:5000/oauth/callback
PLAID_REDIRECT_URI=http://127.0.0.1:5000/oauth/callback

# Optional named Link customization for Data Transparency Messaging in production
# Example: personal-finance
PLAID_LINK_CUSTOMIZATION_NAME=

# Optional webhook for product readiness and updates
PLAID_WEBHOOK=http://127.0.0.1:5000/webhook

# Optional: Fernet key (urlsafe base64) to encrypt Plaid access tokens in SQLite at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PLAID_TOKEN_ENCRYPTION_KEY=

# Production TLS: trust X-Forwarded-* from reverse proxy (nginx, etc.)
# TRUST_PROXY_HEADERS=1
# Redirect browser HTTP→HTTPS (skips localhost). Use with a terminating proxy.
# PUBLIC_REQUIRE_HTTPS=1

# Umbrel (Lightning + RPC) — optional; you can keep these in .env only if you prefer
UMBREL_LIGHTNING_MACAROON=
UMBREL_RPC_PASS=

# Cold storage (Sparrow xpub via Umbrel Electrum server)
BTC_WALLET_XPUB=your_xpub_here
BTC_WALLET_ADDRESS_TYPE=p2pkh
BTC_WALLET_GAP_LIMIT=20
BTC_ELECTRUM_HOST=umbrel.local
BTC_ELECTRUM_PORT=50001
BTC_ELECTRUM_SSL=false
BTC_WALLET_CACHE_TTL=300

# Streamlit auto-start (Quant backtesting)
STREAMLIT_AUTO_START=true

# Gemini API (SEC filings summaries)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional summary fallbacks
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# News: Groq holdings relevance (POC; cost-efficient defaults). Requires GROQ_API_KEY.
# NEWS_AI_ENABLED=1
# Small/fast model by default; override if needed:
# NEWS_AI_GROQ_MODEL=llama-3.1-8b-instant
# Max articles per digest run (default 3). Increase slowly — each call uses API tokens.
# NEWS_AI_MAX_ARTICLES_PER_RUN=3
# Truncate title+summary input (default ~2400 chars).
# NEWS_AI_MAX_INPUT_CHARS=2400
# Only consider articles first seen within this many days (default 2).
# NEWS_AI_LOOKBACK_DAYS=2

# Home page: Groq cross-insights (news + SEC filing summaries). Uses GROQ_API_KEY.
# HOME_INSIGHTS_ENABLED=1
# HOME_INSIGHTS_GROQ_MODEL=llama-3.1-8b-instant
# Optional tuning (defaults are higher than legacy: more news/SEC text, portfolio-first news pick):
# HOME_INSIGHTS_MAX_NEWS=36
# HOME_INSIGHTS_MAX_SEC=14
# HOME_INSIGHTS_MAX_NEWS_SUMMARY=480
# HOME_INSIGHTS_MAX_SEC_SUMMARY=720
# HOME_INSIGHTS_MAX_PROMPT_CHARS=18000
# HOME_INSIGHTS_GROQ_MAX_TOKENS=1100
# Max portfolio symbols to query for tagged articles (0 = skip ticker pass, general digest only):
# HOME_INSIGHTS_PORTFOLIO_TICKERS_MAX=20
# Articles per ticker query before filling with general recent digest:
# HOME_INSIGHTS_PER_TICKER_NEWS=4
# Max source rows returned to the UI from the model (default 40):
# HOME_INSIGHTS_MAX_SOURCE_LABELS=40
# Simulated backtest rows in the insights prompt (default 8):
# HOME_INSIGHTS_MAX_QUANT=8
# Daily portfolio risk card snapshots in the prompt (default 14):
# HOME_INSIGHTS_MAX_RISK_SNAPSHOTS=14
# Keep quant_risk_snapshots rows for this many days (default 120); set 0 to skip pruning.
# QUANT_RISK_SNAPSHOT_RETENTION_DAYS=120
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
GEMINI_MODEL=gemini-2.0-flash

# SEC filings retention (days). Set 0 to disable pruning.
SEC_FILINGS_RETENTION_DAYS=30
# Cached LLM summaries in sec_filing_summaries (longer than raw files). Set 0 to never prune.
# SEC_FILING_SUMMARY_RETENTION_DAYS=365

# Groq fallback (optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Hugging Face fallback (optional)
HF_API_KEY=your_hf_api_key_here
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Optional: unified switch — enables both client (POST /api/client_error) and server (unhandled exception) DB logs
# ENABLE_ERROR_LOG=1
# Or enable separately:
# ENABLE_CLIENT_ERROR_LOG=1
# ENABLE_SERVER_ERROR_LOG=1
# Delete error log rows older than N days (default 30). Set to 0 to disable pruning.
# ERROR_LOG_RETENTION_DAYS=30

# SEC EDGAR user agent info (required by SEC policy)
SEC_EDGAR_COMPANY=your_name_or_app
SEC_EDGAR_EMAIL=your_email@domain.com
SEC_EDGAR_USER_AGENT=your_name_or_app your_email@domain.com
SEC_FILINGS_RETENTION_DAYS=30
